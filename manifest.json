{
  "manifest_version": 3,
  "name": "CoinWatch",
  "version": "1.0.0",
  "description": "Cross-chain crypto watchlist — track any token on ETH, SOL, Base, BSC, ARB & 20+ chains with live prices, alerts, and one-click add from chart sites.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://api.dexscreener.com/*",
    "https://datapi.jup.ag/*",
    "https://api.binance.com/*",
    "https://cdn.dexscreener.com/*",
    "https://assets.coincap.io/*",
    "https://api.coincap.io/*",
    "https://api.dexpaprika.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CoinWatch",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["ExtPay.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://dexscreener.com/*",
        "https://birdeye.so/*",
        "https://www.geckoterminal.com/*",
        "https://geckoterminal.com/*",
        "https://www.dextools.io/*",
        "https://dextools.io/*",
        "https://defined.fi/*",
        "https://gmgn.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+W",
        "mac": "MacCtrl+Shift+W"
      },
      "description": "Open CoinWatch popup"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}